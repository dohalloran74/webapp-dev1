{{> welcomemenu id="signup"}}
<!-- create a registration form with fields for first name, last name, email, password and profile picture -->
<form class="ui stacked segment form" action="/register" method="POST" enctype="multipart/form-data">


  <h3 class="ui header">Register</h3>
  <div class="two fields">
    <div class="field">
      <label for="firstName">First Name</label>
      <input placeholder="First Name" type="text"  name="firstName" autofocus required>
    </div>
    <div class="field">
      <label for="lastName">Last Name</label>
      <input placeholder="Last Name" type="text"  name="lastName" required>
    </div>
  </div>
  <div class="field">
    <label for="email">Email</label>
    <input placeholder="Email" type="text" name="email" required>
  </div>
  <div class="field">
    <label for="password">Password</label>
    <input type="password" name="password" required>
  </div>
<!--add submit button and file input for profile picture-->
  <div class="field">
  <label for="picture">Profile Picture</label>
  <input type="file" name="picture" accept="image/*" required>
</div>

  <button class="ui blue submit button">Submit</button>
</form>
